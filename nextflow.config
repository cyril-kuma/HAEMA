manifest {
    name            = 'haema/bloodmeal-metabarcoding'
    author          = 'HÆMA project'
    homePage        = 'https://github.com/cyril-kuma/HAEMA'
    description     = 'ONT multiplexed blood-meal metabarcoding pipeline for Anopheles gambiae s.l.'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.10.0'
    version         = '0.4.0'
}

// Schema-based parameter validation and `--help` (nf-schema, version-pinned).
// Downloaded once and cached; for offline/air-gapped use pre-stage with
// `nextflow plugin install nf-schema@2.2.0` or set NXF_PLUGINS_DIR.
plugins {
    id 'nf-schema@2.2.0'
}

validation {
    lenientMode = false
    help {
        enabled = true
        command = 'nextflow run haema -profile test,docker --skip_taxonomy false --outdir results/test'
        beforeText = """
------------------------------------------------------------------------------
 HÆMA — ONT blood-meal metabarcoding pipeline
------------------------------------------------------------------------------
 First run (bundled demo, no data needed):
   nextflow run . -profile test,docker --skip_taxonomy false --outdir results/test

 Real run:
   nextflow run . -profile local --input <samplesheet.csv> --raw_data_dir <Runs/> \\
     --python_container haema-python:0.3.0 --outdir results/run

 Parameters (group --help with --help <group>, e.g. --help taxonomy):
"""
        afterText = """
 Docs: docs/usage.md · docs/parameters.md · docs/output.md   |   Reference: nextflow_schema.json
------------------------------------------------------------------------------
"""
    }
    summary {
        beforeText = "HÆMA run parameters (non-default):\n"
        afterText  = "\n"
    }
}

// Work directory is relative to where you launch Nextflow, so a fresh clone is self-contained
// and -resume caching is predictable. Override with -w / NXF_WORK if you want a scratch volume.
workDir = "${launchDir}/work"

params {
    // Required inputs (no default): the pipeline fails fast with a clear message if missing.
    // For a zero-config first run use `-profile test`, which supplies bundled example data.
    input          = ''
    raw_data_dir   = ''
    // Self-contained assets shipped with the repo (override to use your own).
    primers        = "${projectDir}/assets/primers.csv"
    reference_fasta = "${projectDir}/assets/references/vertebrate_dna_ref_panel.fasta"
    outdir         = "${launchDir}/results"
    log_dir        = "${launchDir}/logs"

    help           = false
    production_mode = false
    input_type     = 'fastq'
    fastq_extensions = '.fastq.gz,.fq.gz,.fastq,.fq'
    require_fastqs = true
    strict_metadata = false
    strict_barcode_filenames = false

    barcode_kit    = 'SQK-RBK114-96'
    flowcell       = 'R10.4.1'
    demux_strategy = 'pre_demultiplexed_minknow_trusted_folder'
    basecalling_model = 'r1041_e82_400bps_sup_v4.3.0'
    pooled_fastq   = ''
    enable_advanced_demux = false
    advanced_demux_tool = 'header_tag'
    advanced_demux_command_template = ''
    advanced_demux_min_reads_per_barcode = 1
    demux_run_id = 'ADVANCED_DEMUX'

    marker_windows = ''
    marker_window_padding = 75
    min_mean_q = 20
    min_read_length = 100
    primer_search_window = 90
    primer_max_error_rate = 0.15
    allow_length_fallback = true

    consensus_method = 'cluster'
    enable_mixed_denoising = true
    mixed_denoise_backend = 'umap_hdbscan'
    mixed_denoise_kmer_size = 5
    // Production defaults tuned for real ONT amplicon depth: a confident host template needs
    // >=20 supporting reads AND >=5% of the marker's reads. Lower values (e.g. 3 / 0.01, as the
    // test profile uses) over-split noisy reads into many micro-clusters on real data. For
    // shallow data or low-abundance minority-host sensitivity, lower these and benchmark against
    // mixed-host positive controls.
    mixed_denoise_min_cluster_size = 20
    mixed_denoise_min_cluster_fraction = 0.05
    mixed_denoise_min_reads_for_umap = 50
    mixed_denoise_allow_greedy_fallback = true
    min_asv_reads = 3
    min_asv_fraction = 0.01
    min_cluster_identity = 0.97
    // Medaka consensus polishing is ON by default. It needs the pinned ONT Medaka image (multi-GB,
    // pulled once) and a model that exists in that image (verified at runtime by
    // MEDAKA_MODEL_PREFLIGHT). The tiny `test` profile turns it off to stay fast/CI-friendly.
    enable_medaka = true
    medaka_model = 'r1041_e82_400bps_sup_v4.3.0'
    medaka_extra_args = ''
    // Clusters with fewer than this many reads skip polishing (meaningless/crash-prone on a
    // handful of reads, e.g. negative-control clusters) and keep their unpolished consensus.
    medaka_min_reads = 10

    skip_taxonomy = false
    taxonomy_strategy = 'curated_then_fallback'
    reference_mode = 'curated_panel'
    blast_db = ''
    fallback_blast_db = ''
    remote_blast_db = 'core_nt'
    blast_db_mount = ''
    reference_db_label = 'curated_panel'
    blast_db_label = 'external_blast'
    fallback_blast_db_label = 'nt'
    blast_max_target_seqs = 10
    blast_evalue = '1e-20'
    blast_extra_args = ''
    min_blast_identity = 97.0
    min_blast_coverage = 80.0
    top_bitscore_delta = 2.0
    taxonomy_assignment_method = 'conservative_lca'
    taxdump_dir = ''
    curated_reference_metadata = "${projectDir}/assets/references/vertebrate_dna_ref_panel.taxonomy.tsv"
    reference_targets = "${projectDir}/assets/references/ghana_west_africa_reference_targets.tsv"
    require_curated_taxids = false
    require_taxdump_for_lca = false
    enable_curated_panel_check = true
    enable_ncbi_remote_fallback = true
    enable_bold_fallback = false
    bold_mode = 'local_fasta'
    bold_fasta = ''
    bold_taxonomy = ''
    coi_species_identity_threshold = 98.0
    cytb_species_identity_threshold = 97.0
    marker_numt_risk = ''
    enable_marker_concordance = true
    enable_host_ecology_comparisons = true
    // Genera excluded as non-host (vector self-hits etc.) from host-use indices when a broad
    // reference database can match the vector; empty = built-in vector default list.
    non_host_genera = ''

    negative_control_multiplier = 1.0
    enable_rambo_model = true
    rambo_min_host_reads = 3
    rambo_min_host_fraction = 0.01
    rambo_include_contaminants = false

    enable_r_outputs = true
    enable_phyloseq = true
    enable_decontam = true
    strict_bioconductor = false
    decontam_threshold = 0.5
    enable_multiqc = true

    // Vector-host ecological indices (HBI, zoophily, diversity) stratification columns.
    eco_index_zone_column = 'collection_region'
    eco_index_species_column = 'sibling_species'
    eco_index_date_column = 'collection_date'
    // Months treated as the wet season for the temporal/seasonal stratum (default Apr–Oct).
    eco_index_wet_months = '4,5,6,7,8,9,10'

    // Publication-ready manuscript figures from the endpoint tables (matplotlib/seaborn).
    enable_figures = true
    figure_formats = 'pdf,svg,png'

    // Streamlined, self-contained publication figure suite (Objective 1): 5 main + supplementary,
    // vector PDF/EPS incl. the GADM bioclimatic-zone map. Renders plot-ready tables only.
    enable_publication_figures = true
    publication_figures_dir = "${launchDir}/results/figures"
    figure_bioclim_column = 'bioclimatic_zone'

    cleanup = false

    // Container images. Defaults are public, pullable, and digest-pinned for reproducibility.
    // The production profile swaps the project-specific custom images in where the public
    // base images cannot satisfy the scientific dependency stack. Digests resolved 2026-06-11
    // and are multi-arch (linux/amd64 + linux/arm64).
    // NB: the default Python image is the full python:3.11 (not -slim) because Nextflow needs
    // `ps` (procps) in the container to collect task metrics; -slim omits it. The custom
    // haema-python image is slim-based and installs procps explicitly.
    python_container = 'python:3.11@sha256:0c3b4dde908ad46418559b4b713a877d535e5d9b7113f5cc80163e31ed32771e'
    blast_container = 'quay.io/biocontainers/blast:2.16.0--hc155240_3@sha256:44d9d07f8cf90fe722013f4fbe0230f3013f49ff7f8432b3ba1e8563b81733eb'
    advanced_demux_container = 'python:3.11@sha256:0c3b4dde908ad46418559b4b713a877d535e5d9b7113f5cc80163e31ed32771e'
    // ontresearch/medaka publishes one immutable sha-tag per build plus a moving :latest.
    // Pin the sha-tag (the build that :latest pointed at on 2026-06-11), never :latest.
    medaka_container = 'ontresearch/medaka:shaf39439188c323053e66cf79618fae1ab33d1b38a'
    r_container = 'rocker/r-ver:4.4.2@sha256:df26749182af64d5263bf64149d51a427b476ed28c4e046997143be3f97fdd7c'
    multiqc_container = 'multiqc/multiqc:v1.25@sha256:ad08efaedd4e31b860edf05d058ff16178692924b1b0e74ed1db387ce3ba0ffd'
    // Project-specific image: matplotlib/seaborn/geopandas figure stack is not in a public
    // digest-pinned base. Build it with
    // `docker build -t haema-figures:0.4.0 -f containers/haema-figures/Dockerfile .`
    // (or push to a registry and pass its @sha256 digest), like haema-python / haema-r.
    figures_container = 'haema-figures:0.4.0'
}

// Purge a task's work directory on successful completion when --cleanup true.
// Default false to preserve -resume during development; enable for large production runs.
cleanup = params.cleanup

process {
    executor = 'local'
    container = params.python_container

    // Retry on transient/out-of-memory signals (SIGKILL/OOM = 137, segfault/abort, scheduler
    // kills 130-145, plus 104/247), otherwise fail. Retries get more memory/time via task.attempt.
    errorStrategy = { task.exitStatus in ((130..145) + [104, 247]) ? 'retry' : 'terminate' }
    maxRetries = 2

    // Ceiling so dynamic per-attempt scaling never requests more than the host can give.
    // Laptop/workstation-safe default; the slurm/gpu profiles raise it.
    resourceLimits = [ cpus: 8, memory: 14.GB, time: 24.h ]

    shell = ['/bin/bash', '-euo', 'pipefail']

    withLabel: process_low {
        cpus = 1
        memory = { 2.GB * task.attempt }
        time = { 1.h * task.attempt }
    }

    withLabel: process_medium {
        cpus = 2
        memory = { 6.GB * task.attempt }
        time = { 4.h * task.attempt }
    }

    withLabel: process_high {
        cpus = 4
        memory = { 12.GB * task.attempt }
        time = { 12.h * task.attempt }
    }

    withName: 'MAKE_BLAST_DB|BLASTN_ASVS|BLASTN_EXTERNAL_ASVS|BLASTN_EXTERNAL_PRIMARY|BLASTN_EXTERNAL_FALLBACK' {
        container = params.blast_container
    }

    withName: 'ADVANCED_DEMUX' {
        container = params.advanced_demux_container
    }

    withName: 'DENOISE_MIXED_TEMPLATES|INPUT_VALIDATION|PRODUCTION_PREFLIGHT|CLUSTER_CONSENSUS|DEREPLICATE_ASVS|AGGREGATE_RESULTS|BUILD_REPORT|RAMBO_MIXED_MODEL|BUILD_RUN_MANIFEST|NO_TAXONOMY|ASSIGN_TAXONOMY|ASSIGN_TAXONOMY_WITH_FALLBACK|ASSIGN_TAXONOMY_EXTERNAL_DB' {
        container = params.python_container
    }

    withName: 'MEDAKA_POLISH|MEDAKA_MODEL_PREFLIGHT' {
        container = params.medaka_container
    }

    withName: 'BUILD_R_OUTPUTS|R_BIOCONDUCTOR_PREFLIGHT|PHYLOSEQ_FIGURES' {
        container = params.r_container
    }

    withName: 'MULTIQC_REPORT' {
        container = params.multiqc_container
    }

    withName: 'BUILD_FIGURES|PUBLICATION_FIGURES' {
        container = params.figures_container
    }
}

docker {
    enabled = true
    runOptions = params.blast_db_mount
        ? "-u \$(id -u):\$(id -g) -v ${params.blast_db_mount}:${params.blast_db_mount}:ro"
        : "-u \$(id -u):\$(id -g)"
}

timeline {
    enabled = true
    file = "${params.log_dir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.log_dir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.log_dir}/pipeline_info/execution_trace.tsv"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.log_dir}/pipeline_info/pipeline_dag.html"
    overwrite = true
}

profiles {
    local {
        process.executor = 'local'
        docker.enabled = true
        singularity.enabled = false
        apptainer.enabled = false
        // Adjust to the local machine; default is safe for an 8-core / 16 GB workstation.
        process.resourceLimits = [ cpus: 8, memory: 14.GB, time: 24.h ]
    }

    // Tuned for this specific workstation: 16-thread i9-11950H, 62 GiB RAM, RTX A5000.
    // GPU-in-Docker is intentionally NOT enabled here (the NVIDIA Container Toolkit/CDI is not
    // configured on this host), so Medaka runs CPU-only — the documented safe fallback. Combine
    // with the `docker` profile: `-profile workstation,docker`.
    workstation {
        process.executor = 'local'
        docker.enabled = true
        singularity.enabled = false
        apptainer.enabled = false
        // Schedulable local pool. Leave ~6 GB and a couple of threads for the OS, the Docker
        // daemon, and the Nextflow JVM so a full-depth run cannot lock up the host.
        executor.cpus = 16
        executor.memory = '56 GB'
        // Per-task ceiling for dynamic per-attempt (task.attempt) scaling on OOM/timeout retries.
        // 96 h covers a full 712-barcode run with CPU Medaka polishing.
        process.resourceLimits = [ cpus: 16, memory: 56.GB, time: 96.h ]
        process {
            // The endpoint aggregation and R/phyloseq export steps load every sample's tables at
            // once; on a 712-barcode run that is large enough to have OOM-killed (exit 137) the
            // laptop defaults, so give them generous, per-attempt-scaling headroom.
            withName: 'AGGREGATE_RESULTS' {
                cpus   = 2
                memory = { 24.GB * task.attempt }
                time   = { 6.h * task.attempt }
            }
            withName: 'BUILD_R_OUTPUTS' {
                cpus   = 2
                memory = { 24.GB * task.attempt }
                time   = { 8.h * task.attempt }
            }
            withName: 'BUILD_FIGURES|PHYLOSEQ_FIGURES' {
                cpus   = 2
                memory = { 12.GB * task.attempt }
            }
            withName: 'MULTIQC_REPORT' {
                memory = { 8.GB * task.attempt }
            }
        }
    }

    host {
        process.executor = 'local'
        docker.enabled = false
        singularity.enabled = false
        apptainer.enabled = false
    }

    docker {
        docker.enabled = true
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        // Shared image cache (set NXF_SINGULARITY_CACHEDIR on HPC); falls back to a launch-dir dir.
        singularity.cacheDir = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${launchDir}/singularity_cache"
    }

    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.cacheDir = System.getenv('NXF_APPTAINER_CACHEDIR') ?: System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${launchDir}/apptainer_cache"
    }

    slurm {
        process.executor = 'slurm'
        process.queue = ''
        process.clusterOptions = ''
        executor.queueSize = 50
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${launchDir}/singularity_cache"
        // HPC nodes are larger; raise the ceiling (tune to your partition limits or use -c).
        process.resourceLimits = [ cpus: 64, memory: 256.GB, time: 72.h ]
    }

    gpu {
        // Optional GPU acceleration for Medaka consensus polishing only. Requires an NVIDIA
        // GPU plus the NVIDIA Container Toolkit. Medaka runs CPU-only by default, so dropping
        // this profile is a safe automatic fallback. No other process uses the GPU.
        docker.runOptions = params.blast_db_mount
            ? "-u \$(id -u):\$(id -g) -v ${params.blast_db_mount}:${params.blast_db_mount}:ro --gpus all"
            : "-u \$(id -u):\$(id -g) --gpus all"
        process {
            withName: 'MEDAKA_POLISH' {
                accelerator = 1
            }
        }
    }

    test {
        params.input = "${projectDir}/assets/test_data/samplesheet.csv"
        params.primers = "${projectDir}/assets/test_data/primers.csv"
        params.raw_data_dir = "${projectDir}/assets/test_data/runs"
        params.reference_fasta = "${projectDir}/assets/test_data/references/test_hosts.fasta"
        params.curated_reference_metadata = "${projectDir}/assets/test_data/references/test_hosts_taxonomy.tsv"
        params.reference_targets = "${projectDir}/assets/references/ghana_west_africa_reference_targets.tsv"
        params.outdir = "${launchDir}/results/test_results"
        params.log_dir = "${launchDir}/logs/test_results"
        params.production_mode = false
        params.barcode_kit = 'SQK-RBK114-96'
        params.flowcell = 'R10.4.1'
        params.basecalling_model = 'r1041_e82_400bps_sup_v4.3.0'
        params.marker_windows = 'cyt_b:20:140,co1_short:20:140,co1_long:20:160'
        params.min_mean_q = 0
        params.min_read_length = 20
        params.enable_mixed_denoising = true
        params.mixed_denoise_backend = 'umap_hdbscan'
        params.mixed_denoise_min_cluster_size = 1
        params.mixed_denoise_min_cluster_fraction = 0.0
        params.mixed_denoise_min_reads_for_umap = 999999
        params.min_asv_reads = 1
        params.min_asv_fraction = 0.0
        params.consensus_method = 'dereplicate'
        params.enable_medaka = false
        params.skip_taxonomy = true
        params.require_fastqs = true
        params.strict_metadata = false
        params.strict_barcode_filenames = false
        params.enable_rambo_model = true
        params.rambo_min_host_reads = 1
        params.rambo_min_host_fraction = 0.0
        params.enable_r_outputs = false
        params.enable_phyloseq = false
        params.enable_decontam = false
        params.enable_multiqc = false
        params.enable_figures = false
        params.enable_publication_figures = false
        params.blast_evalue = '10'
        params.blast_extra_args = '-dust no'
        params.min_blast_identity = 90.0
        params.min_blast_coverage = 80.0
        // Tiny ceiling so the smoke test stays light and CI-friendly.
        process.resourceLimits = [ cpus: 2, memory: 4.GB, time: 2.h ]
    }

    production {
        params.production_mode = true
        params.require_fastqs = true
        params.strict_metadata = true
        params.strict_barcode_filenames = false
        params.barcode_kit = 'SQK-RBK114-96'
        params.flowcell = 'R10.4.1'
        params.basecalling_model = 'r1041_e82_400bps_sup_v4.3.0'
        params.demux_strategy = 'pre_demultiplexed_minknow_trusted_folder'
        params.enable_mixed_denoising = true
        params.mixed_denoise_backend = 'umap_hdbscan'
        // Custom image: real UMAP/HDBSCAN denoising stack not present in public python base.
        params.python_container = 'haema-python:0.3.0'
        params.enable_medaka = true
        params.medaka_model = 'r1041_e82_400bps_sup_v4.3.0'
        // Use the pinned upstream ONT image directly (portable, no local build needed); the
        // required model is verified at runtime by MEDAKA_MODEL_PREFLIGHT. Switch to the
        // optional haema-medaka:0.3.0 image if you want the model asserted at build time.
        params.medaka_container = 'ontresearch/medaka:shaf39439188c323053e66cf79618fae1ab33d1b38a'
        params.skip_taxonomy = false
        params.taxonomy_strategy = 'curated_then_fallback'
        params.fallback_blast_db = ''
        params.blast_db_mount = ''
        params.require_curated_taxids = true
        params.require_taxdump_for_lca = true
        params.enable_rambo_model = true
        params.enable_r_outputs = true
        params.enable_phyloseq = true
        params.enable_decontam = true
        params.strict_bioconductor = true
        // Custom image: formal phyloseq/decontam Bioconductor stack not present in public R base.
        params.r_container = 'haema-r:0.3.0'
        params.enable_multiqc = true
    }
}
